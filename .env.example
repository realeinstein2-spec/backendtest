# ============================================================
# MakersHub Backend — Environment Variables Reference
# Copy this file to .env and fill in real values before running
# ============================================================

# --- Database ---
DATABASE_URL=jdbc:postgresql://localhost:5432/makershub
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# --- JWT ---
# REQUIRED. Generate with: openssl rand -base64 64
# The app WILL NOT START if this is missing.
JWT_SECRET=56lQIqkG/AYLTYppvPEnCsGwrEGpUEjLi5a0l69MjXN4zj99+JLdw1bJqT0jtGIRbr6qoxg7AK+NB/4HlttReA==

# --- Paystack ---
# Use sk_test_... for staging, sk_live_... for production
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The URL Paystack redirects users to after payment
PAYSTACK_CALLBACK_URL=https://your-frontend-domain.com/payment/callback

# --- Cloudinary (file uploads) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Firebase Push Notifications ---
FIREBASE_ENABLED=false
FIREBASE_SERVICE_ACCOUNT_PATH=/secrets/firebase-service-account.json

# --- Africa's Talking SMS ---
AFRICAS_TALKING_ENABLED=false
AFRICAS_TALKING_USERNAME=your_username
AFRICAS_TALKING_API_KEY=your_api_key

# --- CORS (comma-separated list of allowed frontend origins) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://makershub.gh

# --- Platform Fee (default 3.5%) ---
PLATFORM_FEE_PERCENT=0.035

# --- Railway / Production ---
PORT=8080
SPRING_PROFILES_ACTIVE=prod

# --- Connection Pool (optional tuning) ---
DB_POOL_MAX=20
DB_POOL_MIN=5
